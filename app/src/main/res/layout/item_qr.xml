<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Barra de color superior según categoría -->
        <View
            android:id="@+id/view_qr_color_bar"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:background="#4CAF50" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp"
            android:gravity="center">

            <!-- Imagen QR generada -->
            <ImageView
                android:id="@+id/img_qr"
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:scaleType="fitCenter"
                android:layout_marginBottom="8dp" />

            <!-- Nombre del residuo -->
            <TextView
                android:id="@+id/txt_qr_nombre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#1B5E20"
                android:gravity="center"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginBottom="2dp" />

            <!-- Categoría -->
            <TextView
                android:id="@+id/txt_qr_categoria"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#4CAF50"
                android:layout_marginBottom="4dp" />

            <!-- Código QR texto -->
            <TextView
                android:id="@+id/txt_qr_codigo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="9sp"
                android:textColor="#9E9E9E"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginBottom="8dp" />

            <!-- Botón compartir / imprimir -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_compartir_qr"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:text="Compartir"
                android:textSize="12sp"
                android:textColor="#2E7D32"
                app:strokeColor="#2E7D32"
                app:cornerRadius="8dp"
                app:icon="@android:drawable/ic_menu_share"
                app:iconTint="#2E7D32"
                app:iconSize="14dp" />

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>