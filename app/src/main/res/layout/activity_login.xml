<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F8E9"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Cabecera verde -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="260dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#1B5E20"
            android:padding="24dp">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_ecolim_logo"
                android:contentDescription="Logo" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ECOLIM S.A.C."
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginTop="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gestión de Residuos Sólidos"
                android:textSize="13sp"
                android:textColor="#A5D6A7"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Card formulario -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="20dp"
            android:layout_marginTop="-30dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Iniciar Sesión"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#1B5E20"
                    android:layout_marginBottom="20dp" />

                <!-- Email -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layout_email"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:hint="Correo electrónico"
                    app:boxStrokeColor="#2E7D32"
                    app:boxBackgroundColor="#FFFFFF"
                    app:hintTextColor="#2E7D32"
                    app:startIconDrawable="@android:drawable/sym_action_email"
                    app:startIconTint="#2E7D32">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edt_email"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textEmailAddress"
                        android:maxLines="1"
                        android:textColor="#000000"
                        android:textColorHint="#9E9E9E"
                        android:background="@android:color/transparent" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Contraseña -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layout_password"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:hint="Contraseña"
                    app:boxStrokeColor="#2E7D32"
                    app:boxBackgroundColor="#FFFFFF"
                    app:hintTextColor="#2E7D32"
                    app:endIconMode="password_toggle"
                    app:endIconTint="#2E7D32"
                    app:startIconDrawable="@android:drawable/ic_lock_lock"
                    app:startIconTint="#2E7D32">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edt_password"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:maxLines="1"
                        android:textColor="#000000"
                        android:textColorHint="#9E9E9E"
                        android:background="@android:color/transparent" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Recordar sesión -->
                <CheckBox
                    android:id="@+id/chk_recordar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Recordar sesión"
                    android:textColor="#555555"
                    android:textSize="13sp"
                    android:buttonTint="#2E7D32"
                    android:layout_marginBottom="20dp" />

                <!-- Botón ingresar -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_ingresar"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Ingresar"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="#2E7D32"
                    app:cornerRadius="12dp" />

                <!-- Separador -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="16dp">
                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#E0E0E0" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="  ¿No tienes cuenta?  "
                        android:textSize="12sp"
                        android:textColor="#9E9E9E" />
                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#E0E0E0" />
                </LinearLayout>

                <!-- Botón registrarse -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_registrarse"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Crear cuenta nueva"
                    android:textSize="15sp"
                    android:textColor="#2E7D32"
                    app:strokeColor="#2E7D32"
                    app:cornerRadius="12dp"
                    app:icon="@android:drawable/ic_input_add"
                    app:iconTint="#2E7D32" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="16dp"
                    android:textSize="11sp"
                    android:textColor="#9E9E9E" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="© 2026 ECOLIM S.A.C."
            android:textSize="10sp"
            android:textColor="#9E9E9E" />

    </LinearLayout>
</ScrollView>