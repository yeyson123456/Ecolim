<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F1F8E9">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.google.android.material.appbar.MaterialToolbar
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#1B5E20"
            app:title="Nuevo Registro"
            app:titleTextColor="#FFFFFF"
            app:subtitle="ECOLIM S.A.C."
            app:subtitleTextColor="#A5D6A7" />
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- TIPO DE RESIDUO -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Título + botones QR en misma fila -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="TIPO DE RESIDUO"
                            android:textSize="11sp"
                            android:textColor="#2E7D32"
                            android:textStyle="bold"
                            android:letterSpacing="0.1" />

                        <!-- Escanear QR -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_qr"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="34dp"
                            android:layout_marginEnd="6dp"
                            android:text="Escanear"
                            android:textSize="11sp"
                            android:textColor="#2E7D32"
                            app:strokeColor="#2E7D32"
                            app:cornerRadius="17dp"
                            app:icon="@android:drawable/ic_menu_camera"
                            app:iconTint="#2E7D32"
                            app:iconSize="14dp" />

                        <!-- ✅ NUEVO — Ver/Generar QR -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_ver_qr"
                            android:layout_width="wrap_content"
                            android:layout_height="34dp"
                            android:text="Ver QR"
                            android:textSize="11sp"
                            android:textColor="#FFFFFF"
                            app:backgroundTint="#2E7D32"
                            app:cornerRadius="17dp"
                            app:icon="@android:drawable/ic_menu_share"
                            app:iconTint="#FFFFFF"
                            app:iconSize="14dp" />

                    </LinearLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layout_tipo_residuo"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:hint="Seleccione el tipo de residuo *"
                        app:boxStrokeColor="#2E7D32"
                        app:hintTextColor="#2E7D32">
                        <AutoCompleteTextView
                            android:id="@+id/dd_tipo_residuo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none"
                            android:focusable="false"
                            android:textColor="#000000"
                            android:textColorHint="#555555" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layout_categoria"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Categoría (automática)"
                        app:boxStrokeColor="#BDBDBD"
                        app:hintTextColor="#9E9E9E">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edt_categoria"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:focusable="false"
                            android:textColor="#000000"
                            android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CANTIDAD -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CANTIDAD RECOLECTADA"
                        android:textSize="11sp"
                        android:textColor="#2E7D32"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="12dp" />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/layout_cantidad"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:hint="Cantidad *"
                            app:boxStrokeColor="#2E7D32"
                            app:hintTextColor="#2E7D32">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/edt_cantidad"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberDecimal"
                                android:maxLines="1"
                                android:textColor="#000000"
                                android:textColorHint="#555555" />
                        </com.google.android.material.textfield.TextInputLayout>
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/layout_unidad"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="Unidad *"
                            app:boxStrokeColor="#2E7D32"
                            app:hintTextColor="#2E7D32">
                            <AutoCompleteTextView
                                android:id="@+id/dd_unidad"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="none"
                                android:focusable="false"
                                android:textColor="#000000"
                                android:textColorHint="#555555" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ZONA -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ZONA DE RECOLECCIÓN"
                        android:textSize="11sp"
                        android:textColor="#2E7D32"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="12dp" />
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layout_ubicacion"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Área o zona *"
                        app:boxStrokeColor="#2E7D32"
                        app:hintTextColor="#2E7D32">
                        <AutoCompleteTextView
                            android:id="@+id/dd_ubicacion"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textCapWords"
                            android:textColor="#000000"
                            android:textColorHint="#555555" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- FECHA Y HORA -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FECHA Y HORA"
                        android:textSize="11sp"
                        android:textColor="#2E7D32"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="12dp" />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/layout_fecha"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:hint="Fecha"
                            app:boxStrokeColor="#2E7D32"
                            app:hintTextColor="#2E7D32">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/edt_fecha"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:focusable="false"
                                android:maxLines="1"
                                android:textColor="#000000"
                                android:textColorHint="#555555" />
                        </com.google.android.material.textfield.TextInputLayout>
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/layout_hora"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="Hora"
                            app:boxStrokeColor="#2E7D32"
                            app:hintTextColor="#2E7D32">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/edt_hora"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:focusable="false"
                                android:maxLines="1"
                                android:textColor="#000000"
                                android:textColorHint="#555555" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- OBSERVACIONES -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="OBSERVACIONES"
                        android:textSize="11sp"
                        android:textColor="#2E7D32"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="12dp" />
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Notas adicionales (opcional)"
                        app:boxStrokeColor="#2E7D32"
                        app:hintTextColor="#2E7D32">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edt_observaciones"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textMultiLine"
                            android:minLines="3"
                            android:maxLines="5"
                            android:gravity="top"
                            android:textColor="#000000"
                            android:textColorHint="#555555" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- FOTO DEL RESIDUO -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FOTO DEL RESIDUO"
                        android:textSize="11sp"
                        android:textColor="#2E7D32"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="12dp" />
                    <ImageView
                        android:id="@+id/img_foto_residuo"
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:layout_marginBottom="12dp"
                        android:scaleType="centerCrop"
                        android:background="#F5F5F5"
                        android:src="@android:drawable/ic_menu_camera"
                        android:padding="40dp" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_foto"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Agregar foto"
                        android:textColor="#2E7D32"
                        app:strokeColor="#2E7D32"
                        app:cornerRadius="10dp"
                        app:icon="@android:drawable/ic_menu_camera"
                        app:iconTint="#2E7D32" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- Botones fijos -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="#FFFFFF"
        android:elevation="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_limpiar"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Limpiar"
            app:backgroundTint="#EEEEEE"
            android:textColor="#555555"
            app:cornerRadius="10dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_guardar"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="2"
            android:text="Guardar Registro"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            app:backgroundTint="#2E7D32"
            app:cornerRadius="10dp"
            app:icon="@android:drawable/ic_menu_save"
            app:iconTint="#FFFFFF" />

    </LinearLayout>

</LinearLayout>