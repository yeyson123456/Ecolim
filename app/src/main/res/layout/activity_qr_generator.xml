<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F1F8E9">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar_qr"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#1B5E20"
            app:title="Códigos QR"
            app:titleTextColor="#FFFFFF"
            app:subtitle="Escanea para registrar residuos"
            app:subtitleTextColor="#A5D6A7"
            app:navigationIcon="@android:drawable/ic_menu_close_clear_cancel"
            app:navigationIconTint="#FFFFFF" />
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Banner informativo -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#E8F5E9"
        android:padding="12dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Imprime y pega cada QR en el contenedor correspondiente"
            android:textSize="12sp"
            android:textColor="#2E7D32" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_imprimir_todos"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Imprimir todos"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            app:backgroundTint="#2E7D32"
            app:cornerRadius="18dp"
            app:icon="@android:drawable/ic_menu_share"
            app:iconTint="#FFFFFF"
            app:iconSize="14dp" />

    </LinearLayout>

    <!-- Grid de QR codes -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_qr"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false" />

</LinearLayout>